# Copy to .env and fill in. The app runs fully in DEMO mode with NONE of these set.

# ── Splunk (leave blank to force demo/fixtures mode) ──────────────────
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_TOKEN=
# Or username/password instead of a token:
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_VERIFY_SSL=false

# Optional: route the agent's Splunk access through the Splunk MCP Server.
# Run splunk/splunk-mcp-server2 in SSE mode (see docs/MCP_SETUP.md), then set its base URL.
# Leave blank to use the direct REST client.
SPLUNK_MCP_URL=

# ── Planner (optional LLM brain; falls back to the built-in scripted planner) ──
ANTHROPIC_API_KEY=
SENTINEL_MODEL=claude-opus-4-8

# ── App behaviour ─────────────────────────────────────────────────────
# DEMO forces fixtures + scripted planner (never touches the network). Best for the live demo.
SENTINEL_MODE=DEMO
# Seconds between agent steps on screen (higher = more dramatic; 0 = instant)
SENTINEL_STEP_DELAY=0.7
